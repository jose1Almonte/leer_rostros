# ---------------------------------------------------------------------------
# DigitalOcean Spaces (almacenamiento de imágenes, compatible con S3)
# ---------------------------------------------------------------------------
SPACES_KEY=tu_access_key
SPACES_SECRET=tu_secret_key
SPACES_REGION=nyc3
SPACES_BUCKET=nombre-de-tu-space
# Opcionales: por defecto se derivan de la región
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_CDN_ENDPOINT=https://nombre-de-tu-space.nyc3.cdn.digitaloceanspaces.com

# ---------------------------------------------------------------------------
# Base de datos
# Con Docker Compose NO necesitas tocar DATABASE_URL: el compose la genera con
# DB_PASSWORD apuntando al contenedor 'db'. Solo elige una contraseña aquí.
# (Si despliegas SIN Docker, pon la DATABASE_URL de tu Postgres con pgvector.)
# ---------------------------------------------------------------------------
DB_PASSWORD=cambia_esta_clave
DATABASE_URL=postgresql://usuario:password@host:25060/defaultdb?sslmode=require

# ---------------------------------------------------------------------------
# Reconocimiento facial — InsightFace buffalo_l (ArcFace w600k_r50, 512-dim).
# match_threshold = distancia coseno máxima para considerar coincidencia
# (menor = más parecido). buffalo_l + coseno: 0.55 es buen punto de partida.
# EMBEDDING_DIM debe ser 512 (lo exige buffalo_l).
# ---------------------------------------------------------------------------
EMBEDDING_DIM=512
MATCH_THRESHOLD=0.55
MIN_FACE_QUALITY=0.50

# ---------------------------------------------------------------------------
# Admin bootstrap (solo para el primer arranque — sembrar el admin inicial).
# Después del primer arranque se ignoran; el login valida contra la BD.
# ---------------------------------------------------------------------------
# ADMIN_USER=admin
# ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
